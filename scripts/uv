#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LOCAL_UV_BIN="$REPO_ROOT/.tools/bin/uv"

cd "$REPO_ROOT"

if [[ -x "$LOCAL_UV_BIN" ]]; then
  UV_BIN="$LOCAL_UV_BIN"
elif command -v uv >/dev/null 2>&1; then
  UV_BIN="$(command -v uv)"
else
  echo "uv is required. Run ./setup-dev to install it locally into .tools/bin." >&2
  exit 1
fi

export UV_CACHE_DIR="$REPO_ROOT/.tools/uv-cache"
export UV_PROJECT_ENVIRONMENT="$REPO_ROOT/.venv"
export UV_PYTHON_INSTALL_DIR="$REPO_ROOT/.tools/python"
export UV_NO_MODIFY_PATH=1

exec "$UV_BIN" "$@"
