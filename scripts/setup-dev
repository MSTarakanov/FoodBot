#!/usr/bin/env bash
set -euo pipefail

OFFICIAL_REPO_SSH="git@github.com:MSTarakanov/FoodBot.git"
OFFICIAL_REPO_HTTPS="https://github.com/MSTarakanov/FoodBot.git"
OWNER_PROFILE_URL="https://github.com/MSTarakanov"
COLLABORATOR_REQUEST_ISSUE_URL="https://github.com/MSTarakanov/FoodBot/issues/new?title=Collaborator%20access%20request"
DEFAULT_DATABASE_PATH="foodbot.local.sqlite3"
DEFAULT_TIMEZONE="Europe/Belgrade"

ENV_ONLY=0
SKIP_TOOLS=0
RESET_ENV=0
SKIP_TOKEN_CHECK=0
SHOW_AGENT_GUIDE=0
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
TOOLS_DIR="$REPO_ROOT/.tools"
LOCAL_UV_BIN="$TOOLS_DIR/bin/uv"
UV_BIN=""
GITHUB_SSH_USER=""
OFFICIAL_REPO_ORIGIN=0
OFFICIAL_REPO_WRITE_ACCESS="unknown"
CONTRIBUTION_FLOW=""
DETECTED_TELEGRAM_BOT_USERNAME=""
ENV_TMP_FILE=""

cleanup_setup_dev() {
  if [[ -n "${ENV_TMP_FILE:-}" && -f "$ENV_TMP_FILE" ]]; then
    rm -f "$ENV_TMP_FILE"
  fi
}

trap cleanup_setup_dev EXIT
trap 'cleanup_setup_dev; exit 130' INT TERM HUP

print_step() {
  local title="$1"

  if [[ -t 1 ]]; then
    printf "\n\033[1m==> %s\033[0m\n" "$title"
  else
    printf "\n==> %s\n" "$title"
  fi
}

print_agent_guide() {
  printf "%s\n" \
    "Agent-assisted setup guide" \
    "" \
    "Do not ask the user to paste secrets into chat." \
    "TELEGRAM_BOT_TOKEN, SPLITWISE_API_KEY, SSH key passphrases, and GitHub credentials should be typed by" \
    "the user into a local terminal prompt." \
    "" \
    "Recommended flow:" \
    "1. Make sure the repository is cloned and the working tree is on the setup branch." \
    "2. Tell the user to run ./setup-dev in their terminal, or run it only in a terminal" \
    "   where the user can type prompt answers directly." \
    "3. If GitHub SSH is not ready, let the user choose whether to re-check SSH," \
    "   generate a key and add it to GitHub, continue without SSH, or stop setup." \
    "4. Let setup stop if the Telegram token is invalid; the user should get a real" \
    "   development bot token from @BotFather." \
    "5. After setup completes, run scripts/check." \
    "" \
    "For automated tests only, use --env-only --skip-token-check with dummy tokens."
}

usage() {
  printf "%s\n" \
    "Usage: ./setup-dev [--agent-guide] [--env-only] [--reset-env] [--skip-token-check] [--skip-tools]" \
    "" \
    "Options:" \
    "  --agent-guide  Print safe instructions for AI-agent-assisted setup." \
    "  --env-only    Configure only the local .env file. Used by tests." \
    "  --reset-env   Re-ask local git identity and ignore existing .env values." \
    "  --skip-token-check  Skip Telegram token validation. Used by tests or offline setup." \
    "  --skip-tools  Skip uv, git, SSH, and remote checks."
}

for arg in "$@"; do
  case "$arg" in
    --agent-guide)
      SHOW_AGENT_GUIDE=1
      ;;
    --env-only)
      ENV_ONLY=1
      SKIP_TOOLS=1
      ;;
    --reset-env)
      RESET_ENV=1
      ;;
    --skip-token-check)
      SKIP_TOKEN_CHECK=1
      ;;
    --skip-tools)
      SKIP_TOOLS=1
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $arg" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ "$SHOW_AGENT_GUIDE" -eq 1 ]]; then
  print_agent_guide
  exit 0
fi

if [[ "$ENV_ONLY" -eq 0 ]]; then
  cd "$REPO_ROOT"

  if [[ ! -t 0 ]]; then
    print_agent_guide >&2
    exit 1
  fi
fi

prompt_value() {
  local result_variable="$1"
  local label="$2"
  local current_value="$3"
  local required="$4"
  local secret="$5"
  local answer=""

  if [[ -n "$current_value" ]]; then
    if [[ "$secret" -eq 1 ]]; then
      echo "$label is already configured. Press Enter to keep it."
    else
      echo "$label is currently: $current_value"
    fi
  fi

  if [[ "$secret" -eq 1 && -t 0 ]]; then
    read -r -s -p "$label: " answer
    echo
  else
    read -r -p "$label: " answer
  fi

  if [[ -z "$answer" && -n "$current_value" ]]; then
    answer="$current_value"
  fi

  if [[ "$required" -eq 1 && -z "$answer" ]]; then
    echo "$label is required." >&2
    exit 1
  fi

  printf -v "$result_variable" "%s" "$answer"
}

prompt_yes_no() {
  local result_variable="$1"
  local label="$2"
  local default_answer="$3"
  local suffix="[y/n]"
  local answer=""

  printf "%s %s " "$label" "$suffix"
  read -r answer
  answer="${answer:-$default_answer}"

  case "$answer" in
    [yY] | [yY][eE][sS])
      printf -v "$result_variable" "y"
      ;;
    [nN] | [nN][oO])
      printf -v "$result_variable" "n"
      ;;
    *)
      echo "Please answer yes or no." >&2
      prompt_yes_no "$result_variable" "$label" "$default_answer"
      ;;
  esac
}

prompt_value_or_keep_current() {
  local result_variable="$1"
  local label="$2"
  local current_value="$3"
  local required="$4"
  local keep_label="$5"

  if [[ -n "$current_value" ]]; then
    echo "$label is currently: $current_value"
    local keep_current="y"
    prompt_yes_no keep_current "$keep_label" "y"
    if [[ "$keep_current" == "y" ]]; then
      printf -v "$result_variable" "%s" "$current_value"
      return
    fi
  fi

  prompt_value "$result_variable" "$label" "" "$required" 0
}

prompt_value_with_default() {
  local result_variable="$1"
  local label="$2"
  local default_value="$3"
  local required="$4"
  local answer=""

  if [[ -n "$default_value" ]]; then
    read -r -p "$label [$default_value]: " answer
    answer="${answer:-$default_value}"
  else
    read -r -p "$label: " answer
  fi

  if [[ "$required" -eq 1 && -z "$answer" ]]; then
    echo "$label is required." >&2
    exit 1
  fi

  printf -v "$result_variable" "%s" "$answer"
}

prompt_choice() {
  local result_variable="$1"
  local label="$2"
  local answer=""

  read -r -p "$label " answer
  printf -v "$result_variable" "%s" "$answer"
}

ensure_uv() {
  if [[ -x "$LOCAL_UV_BIN" ]]; then
    UV_BIN="$LOCAL_UV_BIN"
    return
  fi

  echo "Local uv is not installed in .tools/bin."

  if [[ ! -t 0 ]]; then
    echo "Run ./setup-dev interactively to install uv locally into .tools/bin." >&2
    exit 1
  fi

  local install_uv="y"
  prompt_yes_no install_uv "Install uv locally into .tools/bin?" "y"
  if [[ "$install_uv" != "y" ]]; then
    if command -v uv >/dev/null 2>&1; then
      UV_BIN="$(command -v uv)"
      echo "Using uv from PATH for this run: $UV_BIN"
      return
    fi

    echo "Setup stopped. Install uv locally or make uv available in PATH."
    exit 1
  fi

  mkdir -p "$TOOLS_DIR/bin"
  curl -LsSf https://astral.sh/uv/install.sh \
    | env UV_INSTALL_DIR="$TOOLS_DIR/bin" UV_NO_MODIFY_PATH=1 sh

  if [[ ! -x "$LOCAL_UV_BIN" ]]; then
    echo "uv installation finished, but $LOCAL_UV_BIN was not found." >&2
    exit 1
  fi

  UV_BIN="$LOCAL_UV_BIN"
}

configure_python_environment() {
  print_step "Python toolchain"

  export UV_CACHE_DIR="$TOOLS_DIR/uv-cache"
  export UV_PROJECT_ENVIRONMENT="$REPO_ROOT/.venv"
  export UV_PYTHON_INSTALL_DIR="$TOOLS_DIR/python"
  export UV_NO_MODIFY_PATH=1

  ensure_uv
  "$UV_BIN" python install 3.14
  "$UV_BIN" sync --extra dev
}

linked_worktree_source_root() {
  if [[ ! -f "$REPO_ROOT/.git" ]]; then
    return
  fi

  local common_git_dir=""
  common_git_dir="$(
    git -C "$REPO_ROOT" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true
  )"
  if [[ -z "$common_git_dir" || "$(basename "$common_git_dir")" != ".git" ]]; then
    return
  fi

  local source_root=""
  source_root="$(dirname "$common_git_dir")"
  if [[ "$source_root" == "$REPO_ROOT" || ! -d "$source_root" ]]; then
    return
  fi

  printf "%s" "$source_root"
}

state_path_in_root() {
  local root="$1"
  local path="$2"

  if [[ "$path" == /* ]]; then
    printf "%s" "$path"
  else
    printf "%s/%s" "$root" "$path"
  fi
}

copy_env_from_linked_worktree() {
  local source_root="$1"
  local source_env="$source_root/.env"
  local target_env="$REPO_ROOT/.env"

  if [[ "$RESET_ENV" -eq 1 || ! -f "$source_env" || -e "$target_env" || -L "$target_env" ]]; then
    return
  fi

  cp "$source_env" "$target_env"
  chmod 600 "$target_env"
  echo "Imported local .env values from $source_root."
}

link_state_path() {
  local source_path="$1"
  local target_path="$2"
  local label="$3"

  if [[ ! -e "$source_path" || -e "$target_path" || -L "$target_path" ]]; then
    return
  fi

  ln -s "$source_path" "$target_path"
  echo "Linked $label -> $source_path"
}

link_database_from_linked_worktree() {
  local source_root="$1"
  local source_env="$source_root/.env"
  local database_path=""

  database_path="$(read_env_value DATABASE_PATH "$source_env" || true)"
  database_path="${database_path:-$DEFAULT_DATABASE_PATH}"
  if [[ "$database_path" == /* ]]; then
    return
  fi

  local source_database=""
  local target_database=""
  source_database="$(state_path_in_root "$source_root" "$database_path")"
  target_database="$(state_path_in_root "$REPO_ROOT" "$database_path")"

  link_state_path "$source_database" "$target_database" "$database_path"
}

configure_linked_worktree_state() {
  if [[ "$ENV_ONLY" -eq 1 ]]; then
    return
  fi

  local source_root=""
  source_root="$(linked_worktree_source_root || true)"
  if [[ -z "$source_root" ]]; then
    return
  fi

  local has_state=0
  if [[ "$RESET_ENV" -eq 0 && -f "$source_root/.env" && ! -e "$REPO_ROOT/.env" && ! -L "$REPO_ROOT/.env" ]]; then
    has_state=1
  fi
  if [[ -e "$source_root/.tools" && ! -e "$REPO_ROOT/.tools" && ! -L "$REPO_ROOT/.tools" ]]; then
    has_state=1
  fi

  local source_database_path=""
  source_database_path="$(read_env_value DATABASE_PATH "$source_root/.env" || true)"
  source_database_path="${source_database_path:-$DEFAULT_DATABASE_PATH}"
  if [[ "$source_database_path" != /* ]]; then
    local source_database=""
    local target_database=""
    source_database="$(state_path_in_root "$source_root" "$source_database_path")"
    target_database="$(state_path_in_root "$REPO_ROOT" "$source_database_path")"
    if [[ -e "$source_database" && ! -e "$target_database" && ! -L "$target_database" ]]; then
      has_state=1
    fi
  fi

  if [[ "$has_state" -eq 0 ]]; then
    return
  fi

  print_step "Linked worktree local state"
  printf "%s\n" \
    "This checkout is a linked git worktree." \
    "Setup can reuse ignored local state from:" \
    "  $source_root" \
    "" \
    "This helps feature worktrees use the same local bot token, uv/python cache," \
    "and SQLite debug/registration state."

  local reuse_state="y"
  prompt_yes_no reuse_state "Reuse local state from that worktree?" "y"
  if [[ "$reuse_state" != "y" ]]; then
    echo "Keeping this worktree independent."
    return
  fi

  copy_env_from_linked_worktree "$source_root"
  link_state_path "$source_root/.tools" "$REPO_ROOT/.tools" ".tools"
  link_database_from_linked_worktree "$source_root"
}

configure_git_identity() {
  print_step "Git identity"

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Not inside a git repository; skipping git config."
    return
  fi

  git config --local core.hooksPath .githooks

  local git_name=""
  local git_email=""
  git_name="$(git config --local --get user.name || true)"
  git_email="$(git config --local --get user.email || true)"

  echo
  echo "Git identity is written only to this clone with git config --local."
  if [[ "$RESET_ENV" -eq 0 && -n "$git_name" && -n "$git_email" ]]; then
    echo "Git identity is already configured for this clone."
    return
  fi

  prompt_value git_name "Git user.name" "$git_name" 1 0
  prompt_value git_email "Git user.email" "$git_email" 1 0

  git config --local user.name "$git_name"
  git config --local user.email "$git_email"
  echo "Local git identity and hooks are configured."
}

print_github_ssh_help() {
  printf "%s\n" \
    "To push over SSH:" \
    "1. Check whether you already have a public key:" \
    "   ls ~/.ssh/*.pub" \
    "2. If you do not have one, create it:" \
    "   ssh-keygen -t ed25519 -C \"your-email@example.com\"" \
    "3. Copy the public key:" \
    "   cat ~/.ssh/id_ed25519.pub" \
    "4. Add it in GitHub: Settings -> SSH and GPG keys -> New SSH key." \
    "5. Re-run:" \
    "   ./setup-dev" \
    "" \
    "The SSH key authenticates your GitHub account. It does not grant write access to" \
    "MSTarakanov/FoodBot by itself. Without collaborator access, push to your fork."
}

generate_github_ssh_key() {
  local git_email=""
  local key_path="$HOME/.ssh/id_ed25519"

  git_email="$(git config --local --get user.email || true)"
  if [[ -n "$git_email" ]]; then
    echo "GitHub email for SSH key label is currently: $git_email"
    local use_current_email="y"
    prompt_yes_no use_current_email "Use this email for SSH key label?" "y"
    if [[ "$use_current_email" != "y" ]]; then
      prompt_value git_email "New GitHub email for SSH key label" "" 1 0
    fi
  else
    prompt_value git_email "GitHub email for SSH key label" "" 1 0
  fi

  if [[ -e "$key_path" || -e "$key_path.pub" ]]; then
    echo "$key_path already exists; leaving existing SSH key unchanged."
  else
    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"
    ssh-keygen -t ed25519 -C "$git_email" -f "$key_path"
  fi

  if [[ ! -f "$key_path.pub" ]]; then
    echo "Public key was not found at $key_path.pub" >&2
    return 1
  fi

  printf "%s\n" \
    "" \
    "Add this public key to GitHub:" \
    "GitHub -> Settings -> SSH and GPG keys -> New SSH key" \
    ""
  cat "$key_path.pub"
  printf "%s\n" ""
}

check_github_ssh() {
  print_step "GitHub SSH"
  echo "Checking GitHub SSH authentication..."

  while true; do
    local ssh_output=""
    ssh_output="$(
      ssh -T \
        -o ConnectTimeout=5 \
        -o NumberOfPasswordPrompts=1 \
        -o PreferredAuthentications=publickey \
        git@github.com 2>&1 || true
    )"

    if [[ "$ssh_output" == *"successfully authenticated"* ]]; then
      printf "%s\n" "$ssh_output"
      GITHUB_SSH_USER="$(printf "%s\n" "$ssh_output" | sed -n 's/^Hi \([^!]*\)!.*/\1/p' | head -n 1)"
      echo "GitHub SSH authentication works."
      return
    fi

    printf "%s\n" \
      "GitHub SSH authentication is not ready." \
      ""
    if [[ -n "$ssh_output" ]]; then
      printf "%s\n" "SSH check output:" "$ssh_output" ""
    fi
    print_github_ssh_help

    printf "%s\n" \
      "" \
      "Choose next step:" \
      "  1) Re-check SSH after you add the key in GitHub" \
      "  2) Generate an ed25519 SSH key and print its public key" \
      "  3) Continue without working SSH" \
      "  4) Stop setup"

    local ssh_choice=""
    prompt_choice ssh_choice "Select 1-4 [4]:"
    ssh_choice="${ssh_choice:-4}"

    case "$ssh_choice" in
      1)
        echo "Re-checking GitHub SSH..."
        continue
        ;;
      2)
        generate_github_ssh_key
        continue
        ;;
      3)
        echo "Continuing without GitHub SSH. Push over SSH will not work yet."
        return
        ;;
      4)
        echo "Setup stopped. Re-run ./setup-dev after GitHub SSH is ready."
        exit 1
        ;;
      *)
        echo "Please choose 1, 2, 3, or 4." >&2
        ;;
    esac
  done
}

is_official_repo_url() {
  local url="$1"
  case "$url" in
    "$OFFICIAL_REPO_SSH" | "$OFFICIAL_REPO_HTTPS" | "git@github.com:MSTarakanov/FoodBot" | "https://github.com/MSTarakanov/FoodBot")
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

github_user_ref_slug() {
  local user="$1"
  local slug=""

  slug="$(printf "%s" "${user:-unknown}" | tr -c '[:alnum:]_.-' '-')"
  slug="${slug#.}"
  slug="${slug%.}"
  slug="${slug:-unknown}"
  printf "%s" "$slug"
}

check_official_repo_write_access() {
  OFFICIAL_REPO_WRITE_ACCESS="unknown"

  if [[ -z "$GITHUB_SSH_USER" ]]; then
    return
  fi

  local user_slug=""
  local check_ref=""
  local push_output=""
  local push_status=0

  user_slug="$(github_user_ref_slug "$GITHUB_SSH_USER")"
  check_ref="refs/heads/setup-access-check/$user_slug"

  set +e
  push_output="$(
    git push \
      --dry-run \
      --no-verify \
      "$OFFICIAL_REPO_SSH" \
      "HEAD:$check_ref" 2>&1
  )"
  push_status=$?
  set -e

  if [[ "$push_status" -eq 0 ]]; then
    OFFICIAL_REPO_WRITE_ACCESS="confirmed"
    return
  fi

  case "$push_output" in
    *"Permission to"* | \
      *"permission denied"* | \
      *"Permission denied"* | \
      *"Write access to repository not granted"* | \
      *"Repository not found"*)
      OFFICIAL_REPO_WRITE_ACCESS="denied"
      ;;
    *)
      OFFICIAL_REPO_WRITE_ACCESS="unknown"
      ;;
  esac
}

detect_contribution_flow() {
  local origin_url="$1"
  local upstream_url="$2"

  if [[ -n "$origin_url" ]] && is_official_repo_url "$origin_url"; then
    printf "%s" "direct"
    return
  fi

  if [[ -n "$origin_url" && -n "$upstream_url" ]] && is_official_repo_url "$upstream_url"; then
    printf "%s" "fork"
    return
  fi

  printf "%s" "unknown"
}

contribution_flow_label() {
  case "$1" in
    fork)
      printf "%s" "fork-first"
      ;;
    direct)
      printf "%s" "collaborator/direct"
      ;;
    *)
      printf "%s" "unknown"
      ;;
  esac
}

print_contribution_flow_explanation() {
  printf "%s\n" \
    "Choose how this clone will push branches:" \
    "  1) Fork-first: push to your fork, then open a PR to MSTarakanov/FoodBot." \
    "     Write access to the main repository is not required." \
    "  2) Collaborator/direct: push feature branches directly to MSTarakanov/FoodBot." \
    "     This requires collaborator access."
}

prompt_contribution_flow_choice() {
  local result_variable="$1"
  local default_choice="1"
  local choice=""

  if [[ "$GITHUB_SSH_USER" == "MSTarakanov" ]]; then
    default_choice="2"
  fi

  print_contribution_flow_explanation
  while true; do
    prompt_choice choice "Select 1-2 [$default_choice]:"
    choice="${choice:-$default_choice}"
    case "$choice" in
      1 | fork | fork-first)
        printf -v "$result_variable" "fork"
        return
        ;;
      2 | direct | collaborator | collaborator/direct)
        printf -v "$result_variable" "direct"
        return
        ;;
      *)
        echo "Please choose 1 or 2." >&2
        ;;
    esac
  done
}

select_contribution_flow() {
  local origin_url="$1"
  local upstream_url="$2"
  local detected_flow=""
  detected_flow="$(detect_contribution_flow "$origin_url" "$upstream_url")"

  if [[ "$detected_flow" != "unknown" ]]; then
    local detected_label=""
    local continue_detected="y"
    detected_label="$(contribution_flow_label "$detected_flow")"
    prompt_yes_no \
      continue_detected \
      "Current setup looks like $detected_label. Continue with $detected_label?" \
      "y"
    if [[ "$continue_detected" == "y" ]]; then
      CONTRIBUTION_FLOW="$detected_flow"
      return
    fi
  fi

  prompt_contribution_flow_choice CONTRIBUTION_FLOW
}

prompt_fork_url() {
  local result_variable="$1"
  local fork_default=""
  local fork_url=""

  if [[ -n "$GITHUB_SSH_USER" && "$GITHUB_SSH_USER" != "MSTarakanov" ]]; then
    fork_default="git@github.com:$GITHUB_SSH_USER/FoodBot.git"
  fi

  while true; do
    echo "Fork SSH URL, for example git@github.com:your-user/FoodBot.git"
    prompt_value_with_default fork_url "Fork SSH URL" "$fork_default" 1
    if is_official_repo_url "$fork_url"; then
      echo "Fork SSH URL must point to your fork, not MSTarakanov/FoodBot." >&2
      continue
    fi
    printf -v "$result_variable" "%s" "$fork_url"
    return
  done
}

set_origin_url() {
  local origin_url="$1"
  local target_url="$2"

  if [[ -z "$origin_url" ]]; then
    git remote add origin "$target_url"
  elif [[ "$origin_url" != "$target_url" ]]; then
    git remote set-url origin "$target_url"
  else
    return
  fi
  echo "origin -> $target_url"
}

configure_upstream_official() {
  local upstream_url="$1"

  if [[ -z "$upstream_url" ]]; then
    git remote add upstream "$OFFICIAL_REPO_SSH"
    echo "upstream -> $OFFICIAL_REPO_SSH"
  elif is_official_repo_url "$upstream_url"; then
    if [[ "$upstream_url" != "$OFFICIAL_REPO_SSH" ]]; then
      git remote set-url upstream "$OFFICIAL_REPO_SSH"
      echo "upstream -> $OFFICIAL_REPO_SSH"
    fi
  else
    echo "upstream does not point to MSTarakanov/FoodBot; leaving it unchanged."
  fi
}

configure_fork_flow() {
  local origin_url="$1"
  local upstream_url="$2"
  local selected_fork_url=""

  CONTRIBUTION_FLOW="fork"
  OFFICIAL_REPO_ORIGIN=0
  OFFICIAL_REPO_WRITE_ACCESS="unknown"

  if [[ -n "$origin_url" ]] && ! is_official_repo_url "$origin_url"; then
    echo "Keeping fork origin: $origin_url"
  else
    prompt_fork_url selected_fork_url
    set_origin_url "$origin_url" "$selected_fork_url"
  fi

  configure_upstream_official "$upstream_url"
}

print_write_access_result() {
  case "$OFFICIAL_REPO_WRITE_ACCESS" in
    confirmed)
      echo "Write access to MSTarakanov/FoodBot confirmed."
      ;;
    denied)
      echo "Write access to MSTarakanov/FoodBot is not confirmed."
      ;;
    unknown)
      echo "Could not reliably check write access to MSTarakanov/FoodBot."
      ;;
  esac
}

print_collaborator_access_help() {
  printf "%s\n" \
    "Write access is not confirmed. Ask the repository owner for collaborator access, then re-run ./setup-dev." \
    "Owner profile: $OWNER_PROFILE_URL" \
    "Optional request issue: $COLLABORATOR_REQUEST_ISSUE_URL"
}

configure_direct_flow() {
  local origin_url="$1"
  local upstream_url="$2"

  CONTRIBUTION_FLOW="direct"
  OFFICIAL_REPO_ORIGIN=1

  if [[ "$origin_url" != "$OFFICIAL_REPO_SSH" ]]; then
    set_origin_url "$origin_url" "$OFFICIAL_REPO_SSH"
  fi

  if [[ "$GITHUB_SSH_USER" == "MSTarakanov" ]]; then
    OFFICIAL_REPO_WRITE_ACCESS="confirmed"
    echo "GitHub SSH authenticated as repository owner MSTarakanov."
    return
  fi

  echo "Checking write access to MSTarakanov/FoodBot with a dry-run push..."
  check_official_repo_write_access
  print_write_access_result

  if [[ "$OFFICIAL_REPO_WRITE_ACCESS" == "confirmed" ]]; then
    return
  fi

  print_collaborator_access_help

  local configure_fork="y"
  prompt_yes_no configure_fork "Configure fork-first instead?" "y"
  if [[ "$configure_fork" == "y" ]]; then
    configure_fork_flow "$OFFICIAL_REPO_SSH" "$upstream_url"
  fi
}

configure_git_remotes() {
  print_step "Git contribution flow"

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Not inside a git repository; skipping remote checks."
    return
  fi

  local origin_url=""
  local upstream_url=""
  origin_url="$(git remote get-url origin 2>/dev/null || true)"
  upstream_url="$(git remote get-url upstream 2>/dev/null || true)"

  echo "Git remotes:"
  echo "  origin: ${origin_url:-not configured}"
  echo "  upstream: ${upstream_url:-not configured}"

  select_contribution_flow "$origin_url" "$upstream_url"

  case "$CONTRIBUTION_FLOW" in
    fork)
      configure_fork_flow "$origin_url" "$upstream_url"
      ;;
    direct)
      configure_direct_flow "$origin_url" "$upstream_url"
      ;;
  esac
}

print_contribution_flow_next_steps() {
  if [[ -z "$CONTRIBUTION_FLOW" ]]; then
    return
  fi

  echo
  echo "Git contribution flow:"
  echo "  $(contribution_flow_label "$CONTRIBUTION_FLOW")"
  echo "  SSH user: ${GITHUB_SSH_USER:-unknown}"

  case "$CONTRIBUTION_FLOW" in
    fork)
      echo
      echo "Feature flow:"
      echo "  git checkout -b feature/name"
      echo "  git push origin feature/name"
      echo "  Open a pull request from your fork to MSTarakanov/FoodBot."
      ;;
    direct)
      case "$OFFICIAL_REPO_WRITE_ACCESS" in
        confirmed)
          echo "  Write access to MSTarakanov/FoodBot: confirmed"
          echo
          echo "Feature flow:"
          echo "  git checkout -b feature/name"
          echo "  git push origin feature/name"
          ;;
        denied)
          echo "  Write access to MSTarakanov/FoodBot: not confirmed"
          echo
          print_collaborator_access_help
          ;;
        unknown)
          echo "  Write access to MSTarakanov/FoodBot: could not be checked"
          echo
          print_collaborator_access_help
          ;;
      esac
      ;;
  esac
}

read_env_value() {
  local key="$1"
  local env_file="${2:-.env}"

  if [[ ! -f "$env_file" ]]; then
    return
  fi

  local line=""
  local value=""
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^[[:space:]]*(export[[:space:]]+)?${key}[[:space:]]*=[[:space:]]*(.*)$ ]]; then
      value="${BASH_REMATCH[2]}"
      value="${value%%#*}"
      value="${value#"${value%%[![:space:]]*}"}"
      value="${value%"${value##*[![:space:]]}"}"

      if [[ "$value" == \"*\" && "$value" == *\" ]]; then
        value="${value:1:${#value}-2}"
      elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
        value="${value:1:${#value}-2}"
      fi

      printf "%s" "$value"
      return
    fi
  done <"$env_file"
}

print_botfather_instructions() {
  echo "Get the token from Telegram @BotFather:"
  echo "1. Open @BotFather."
  echo "2. Create a new bot with /newbot or choose an existing development bot."
  echo "3. Copy the token and paste it here."
}

print_splitwise_api_key_instructions() {
  echo "Get a Splitwise API key for local development:"
  echo "1. Open https://secure.splitwise.com/apps."
  echo "2. Create an app for this local clone."
  echo "3. Copy the API key. Do not share another developer's key."
}

normalize_admin_ids() {
  local raw_ids="$1"
  raw_ids="${raw_ids//[[:space:]]/}"

  if [[ -z "$raw_ids" ]]; then
    printf "%s" ""
    return
  fi

  if [[ ! "$raw_ids" =~ ^[0-9]+(,[0-9]+)*$ ]]; then
    echo "TELEGRAM_ADMIN_IDS must contain numeric Telegram user ids separated by commas." >&2
    exit 1
  fi

  printf "%s" "$raw_ids"
}

normalize_telegram_bot_username() {
  local raw_username="$1"
  raw_username="${raw_username#"${raw_username%%[![:space:]]*}"}"
  raw_username="${raw_username%"${raw_username##*[![:space:]]}"}"
  raw_username="${raw_username#@}"

  if [[ -z "$raw_username" ]]; then
    echo "TELEGRAM_BOT_USERNAME is required." >&2
    exit 1
  fi

  if [[ ! "$raw_username" =~ ^[A-Za-z0-9_]+$ ]]; then
    echo "TELEGRAM_BOT_USERNAME must contain only letters, digits, and underscores." >&2
    exit 1
  fi

  printf "%s" "$raw_username"
}

telegram_token_has_valid_shape() {
  local token="$1"
  [[ "$token" =~ ^[0-9]+:[A-Za-z0-9_-]{30,}$ ]]
}

verify_telegram_token_with_api() {
  local token="$1"

  local response=""
  response="$(telegram_get_me_response "$token")"

  [[ "$response" == *'"ok":true'* ]]
}

telegram_get_me_response() {
  local token="$1"

  if ! command -v curl >/dev/null 2>&1; then
    echo "curl is required to verify the Telegram bot token." >&2
    return 1
  fi

  printf 'url = "https://api.telegram.org/bot%s/getMe"\n' "$token" \
    | curl --silent --show-error --fail --config - 2>/dev/null || true
}

telegram_bot_id_from_response() {
  local response="$1"

  printf "%s" "$response" | sed -n 's/.*"id":\([0-9][0-9]*\).*/\1/p'
}

telegram_bot_username_from_response() {
  local response="$1"

  printf "%s" "$response" | sed -n 's/.*"username":"\([^"]*\)".*/\1/p'
}

production_telegram_bot_id() {
  read_env_value PRODUCTION_TELEGRAM_BOT_ID "$REPO_ROOT/.env.defaults" || true
}

is_production_telegram_bot_id() {
  local bot_id="$1"
  local production_bot_id=""
  production_bot_id="$(production_telegram_bot_id)"

  [[ -n "$production_bot_id" && "$bot_id" == "$production_bot_id" ]]
}

print_production_bot_token_error() {
  local bot_id="$1"
  local username="$2"
  local username_text="@${username}"

  if [[ -z "$username" ]]; then
    username_text="unknown username"
  fi

  printf "%s\n" \
    "TELEGRAM_BOT_TOKEN belongs to the production bot (${username_text}, id ${bot_id})." \
    "Use a separate development bot token from @BotFather for local runs." >&2
}

prompt_telegram_bot_token() {
  local result_variable="$1"
  local current_value="$2"
  local token=""
  local printed_instructions=0

  if [[ -n "$current_value" && "$SKIP_TOKEN_CHECK" -eq 0 ]]; then
    if telegram_token_has_valid_shape "$current_value"; then
      local current_bot_response=""
      local current_bot_id=""
      local current_bot_username=""
      current_bot_response="$(telegram_get_me_response "$current_value")"
      current_bot_id="$(telegram_bot_id_from_response "$current_bot_response")"
      current_bot_username="$(telegram_bot_username_from_response "$current_bot_response")"
      if [[ -n "$current_bot_username" ]]; then
        if is_production_telegram_bot_id "$current_bot_id"; then
          print_production_bot_token_error "$current_bot_id" "$current_bot_username"
          current_value=""
        else
          echo "Current TELEGRAM_BOT_TOKEN belongs to @$current_bot_username."
          echo "Bot link: https://t.me/$current_bot_username"

          local use_current_bot="y"
          prompt_yes_no use_current_bot "Use this Telegram bot for local development?" "y"
          if [[ "$use_current_bot" == "y" ]]; then
            DETECTED_TELEGRAM_BOT_USERNAME="$current_bot_username"
            printf -v "$result_variable" "%s" "$current_value"
            return
          fi

          current_value=""
        fi
      else
        echo "Current TELEGRAM_BOT_TOKEN is configured, but setup could not verify which bot it belongs to."
        local use_unverified_current_bot="n"
        prompt_yes_no use_unverified_current_bot "Use this unverified Telegram bot token?" "n"
        if [[ "$use_unverified_current_bot" == "y" ]]; then
          printf -v "$result_variable" "%s" "$current_value"
          return
        fi

        current_value=""
      fi
    else
      echo "Current TELEGRAM_BOT_TOKEN does not look like a real BotFather token."
      current_value=""
    fi
  fi

  while true; do
    if [[ -z "$current_value" && "$printed_instructions" -eq 0 ]]; then
      print_botfather_instructions
      printed_instructions=1
    fi

    prompt_value token "TELEGRAM_BOT_TOKEN" "$current_value" 1 1

    if [[ "$SKIP_TOKEN_CHECK" -eq 1 ]]; then
      printf -v "$result_variable" "%s" "$token"
      return
    fi

    if ! telegram_token_has_valid_shape "$token"; then
      echo "TELEGRAM_BOT_TOKEN does not look like a real BotFather token." >&2
      echo "Expected format: digits:long-secret-from-BotFather" >&2
      if [[ -t 0 ]]; then
        current_value=""
        continue
      fi
      exit 1
    fi

    echo "Checking Telegram bot token..."
    local token_response=""
    local token_bot_id=""
    local token_bot_username=""
    token_response="$(telegram_get_me_response "$token")"
    token_bot_id="$(telegram_bot_id_from_response "$token_response")"
    token_bot_username="$(telegram_bot_username_from_response "$token_response")"
    if [[ "$token_response" == *'"ok":true'* ]]; then
      if is_production_telegram_bot_id "$token_bot_id"; then
        print_production_bot_token_error "$token_bot_id" "$token_bot_username"
        if [[ -t 0 ]]; then
          current_value=""
          continue
        fi
        exit 1
      fi

      echo "Telegram bot token verified."
      DETECTED_TELEGRAM_BOT_USERNAME="$token_bot_username"
      printf -v "$result_variable" "%s" "$token"
      return
    fi

    echo "Telegram did not accept this bot token, or the network request failed." >&2
    if [[ -t 0 ]]; then
      current_value=""
      continue
    fi
    exit 1
  done
}

configure_env() {
  print_step "Telegram and Splitwise configuration"

  local env_file=".env"
  local current_token=""
  local current_telegram_bot_username=""
  local current_admin_ids=""
  local current_splitwise_api_key=""
  local current_splitwise_group_id=""
  local telegram_bot_token=""
  local telegram_bot_username=""
  local telegram_admin_ids=""
  local splitwise_api_key=""
  local splitwise_group_id=""
  local make_admin_default="n"
  local make_admin="n"

  if [[ "$RESET_ENV" -eq 1 ]]; then
    echo
    echo "Resetting local .env values."
  else
    current_token="$(read_env_value TELEGRAM_BOT_TOKEN "$env_file" || true)"
    current_telegram_bot_username="$(read_env_value TELEGRAM_BOT_USERNAME "$env_file" || true)"
    current_admin_ids="$(read_env_value TELEGRAM_ADMIN_IDS "$env_file" || true)"
    current_splitwise_api_key="$(read_env_value SPLITWISE_API_KEY "$env_file" || true)"
    current_splitwise_group_id="$(read_env_value SPLITWISE_GROUP_ID "$env_file" || true)"
  fi
  if [[ -z "$current_splitwise_group_id" ]]; then
    current_splitwise_group_id="$(read_env_value SPLITWISE_GROUP_ID ".env.defaults" || true)"
  fi

  echo "Local Telegram bot configuration"
  echo "Use a personal development bot. Do not use the production token while"
  echo "production long polling is running."
  echo
  prompt_telegram_bot_token telegram_bot_token "$current_token"

  if [[ -n "$DETECTED_TELEGRAM_BOT_USERNAME" ]]; then
    telegram_bot_username="$(normalize_telegram_bot_username "$DETECTED_TELEGRAM_BOT_USERNAME")"
    echo "Telegram bot username: @$telegram_bot_username"
  else
    echo
    echo "TELEGRAM_BOT_USERNAME is used to build private-chat links like https://t.me/<username>."
    prompt_value_or_keep_current \
      telegram_bot_username \
      "TELEGRAM_BOT_USERNAME" \
      "$current_telegram_bot_username" \
      1 \
      "Use current TELEGRAM_BOT_USERNAME?"
    telegram_bot_username="$(normalize_telegram_bot_username "$telegram_bot_username")"
  fi

  if [[ -n "$current_admin_ids" ]]; then
    make_admin_default="y"
  fi

  echo
  prompt_yes_no make_admin "Make yourself an admin of the development bot?" "$make_admin_default"
  if [[ "$make_admin" == "y" ]]; then
    echo "Get your Telegram user id:"
    echo "1. Open @userinfobot or @RawDataBot in Telegram."
    echo "2. Send /start."
    echo "3. Copy the numeric Id value."
    prompt_value_or_keep_current \
      telegram_admin_ids \
      "TELEGRAM_ADMIN_IDS" \
      "$current_admin_ids" \
      1 \
      "Use current TELEGRAM_ADMIN_IDS?"
    telegram_admin_ids="$(normalize_admin_ids "$telegram_admin_ids")"
  else
    telegram_admin_ids=""
  fi

  echo
  if [[ -z "$current_splitwise_api_key" ]]; then
    print_splitwise_api_key_instructions
  fi
  prompt_value splitwise_api_key "SPLITWISE_API_KEY" "$current_splitwise_api_key" 1 1
  splitwise_group_id="$current_splitwise_group_id"

  umask 077
  ENV_TMP_FILE="$(mktemp "${env_file}.tmp.XXXXXX")"
  {
    echo "FOODBOT_ENV=development"
    echo "TELEGRAM_BOT_TOKEN=$telegram_bot_token"
    echo "TELEGRAM_BOT_USERNAME=$telegram_bot_username"
    echo "DATABASE_PATH=$DEFAULT_DATABASE_PATH"
    echo "TELEGRAM_ADMIN_IDS=$telegram_admin_ids"
    echo "FOODBOT_TIMEZONE=$DEFAULT_TIMEZONE"
    echo "SPLITWISE_API_KEY=$splitwise_api_key"
    echo "SPLITWISE_GROUP_ID=$splitwise_group_id"
  } >"$ENV_TMP_FILE"

  mv "$ENV_TMP_FILE" "$env_file"
  ENV_TMP_FILE=""

  echo ".env is configured for local development."
}

configure_linked_worktree_state

if [[ "$SKIP_TOOLS" -eq 0 ]]; then
  configure_python_environment
  configure_git_identity
  check_github_ssh
  configure_git_remotes
fi

configure_env

if [[ "$ENV_ONLY" -eq 0 ]]; then
  print_step "Done"
  echo "Local environment is ready."
  print_contribution_flow_next_steps
  echo "Run the bot with:"
  echo "  ./run office-food-bot"
  echo "Run checks with:"
  echo "  scripts/check"
fi
